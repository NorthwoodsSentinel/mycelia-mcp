{
  "name": "@northwoodssentinel/mycelia-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping the Mycelia mutual-aid protocol. Lets any MCP-host (Claude Code, Maestro-conducted agents) browse, claim, respond, and rate Mycelia requests in-cockpit instead of via curl.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "mycelia-mcp": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "license": "AGPL-3.0-or-later",
  "author": "NorthwoodsSentinel",
  "repository": {
    "type": "git",
    "url": "https://github.com/NorthwoodsSentinel/mycelia-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mycelia",
    "mutual-aid",
    "agent-cooperation",
    "claude-code",
    "maestro"
  ]
}
